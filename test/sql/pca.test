# name: test/sql/ml.test
# description: test ml extension
# group: [sql]

require ml

statement ok
PRAGMA threads=1;

statement ok
ATTACH 'test/datasets.duckdb' AS ds;

statement ok
CREATE OR REPLACE TEMP TABLE california AS SELECT * FROM ds.california;

statement ok
CREATE OR REPLACE TEMP TABLE california_train AS SELECT * FROM california LIMIT 16500;

statement ok
CREATE OR REPLACE TEMP TABLE california_test AS SELECT * FROM california LIMIT 4140 OFFSET 16500;

statement ok
CREATE OR REPLACE TEMP TABLE pca_model AS
SELECT model
FROM ml_fit({'model_type':'pca', 'num_components':2, 'whiten':false}, NULL,
			(SELECT * FROM california_train));

statement ok
SET VARIABLE pca_model_blob = (SELECT model FROM pca_model LIMIT 1);

query I
SELECT COUNT(*) FROM california;
----
20640

query I
SELECT octet_length(getvariable('pca_model_blob')) > 0;
----
1

query I
SELECT COUNT(*)
FROM ml_predict(getvariable('pca_model_blob'), (SELECT * FROM california_test));
----
4140

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_predict(getvariable('pca_model_blob'), (SELECT * FROM california_test)));
----
2

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_evaluate(getvariable('pca_model_blob'), (SELECT * FROM california_test)));
----
1

query I
SELECT ml_evaluate(getvariable('pca_model_blob')) IS NOT NULL;
----
1

query I
SELECT total_explained_variance_ratio IS NOT NULL
FROM ml_evaluate(getvariable('pca_model_blob'), (SELECT * FROM california_test));
----
1

statement error
SELECT * FROM ml_fit({'model_type':'unknown'}, NULL, (SELECT MedInc FROM california_train));
----
Unsupported model_type

statement error
SELECT * FROM ml_explain(getvariable('pca_model_blob'), (SELECT * FROM california_test));
----
ml_explain is not supported

statement error
SELECT * FROM ml_predict(getvariable('pca_model_blob'),
	(SELECT MedInc, HouseAge, AveRooms, AveBedrms, Population, AveOccup, Latitude, Longitude
	 FROM california_test));
----
missing feature column

statement error
SELECT * FROM ml_evaluate(getvariable('pca_model_blob'),
	(SELECT MedInc, HouseAge, AveRooms, AveBedrms, Population, AveOccup, Latitude, Longitude
	 FROM california_test));
----
missing feature column
