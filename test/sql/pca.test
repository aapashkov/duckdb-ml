# name: test/sql/ml.test
# description: test ml extension
# group: [sql]

require ml

statement ok
PRAGMA threads=1;

statement ok
ATTACH 'test/datasets.duckdb' AS ds;

statement ok
CREATE OR REPLACE TEMP TABLE california AS SELECT * FROM ds.california;

statement ok
CREATE OR REPLACE TEMP TABLE california_train AS SELECT * FROM california LIMIT 16500;

statement ok
CREATE OR REPLACE TEMP TABLE california_test AS SELECT * FROM california LIMIT 4140 OFFSET 16500;

query I
SELECT COUNT(*)
FROM ml_fit('pca_california', {'model_type':'pca', 'num_components':2, 'whiten':false}, NULL,
			(SELECT * FROM california_train));
----
1

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT *
	  FROM ml_fit('pca_california', {'model_type':'pca', 'num_components':2, 'whiten':false}, NULL,
				 (SELECT * FROM california_train)));
----
7

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT *
	  FROM ml_fit('pca_california', {'model_type':'pca', 'num_components':2, 'whiten':false}, NULL,
				 (SELECT * FROM california_train)));
----
7

statement ok
CREATE OR REPLACE TEMP TABLE pca_fit_v1 AS
SELECT *
FROM ml_fit('pca_california', {'model_type':'pca', 'num_components':2, 'whiten':false}, NULL,
			(SELECT * FROM california_train));

statement ok
CREATE OR REPLACE TEMP TABLE pca_fit_v2 AS
SELECT *
FROM ml_fit('pca_california', {'model_type':'pca', 'num_components':2, 'whiten':false}, NULL,
			(SELECT * FROM california_train));

query I
SELECT COUNT(*) FROM california;
----
20640

query I
SELECT (SELECT model_version FROM pca_fit_v2 LIMIT 1) = (SELECT model_version FROM pca_fit_v1 LIMIT 1) + 1;
----
1

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_models());
----
7

query I
SELECT COUNT(*) > 0
FROM ml_models()
WHERE model_name = 'pca_california';
----
1

query I
SELECT COUNT(*)
FROM ml_predict('pca_california', (SELECT * FROM california_test));
----
4140

query I
SELECT COUNT(*)
FROM ml_predict('pca_california', (SELECT *, 1 AS extra_col FROM california_test), version = 0);
----
4140

query I
SELECT COUNT(*)
FROM ml_predict('pca_california', (SELECT * FROM california_test),
	version = 1);
----
4140

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_predict('pca_california', (SELECT * FROM california_test)));
----
2

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_predict('pca_california', (SELECT *, 1 AS extra_col FROM california_test)));
----
2

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_evaluate('pca_california', (SELECT * FROM california_test)));
----
1

query I
SELECT total_explained_variance_ratio IS NOT NULL
FROM ml_evaluate('pca_california', (SELECT * FROM california_test));
----
1

query I
SELECT total_explained_variance_ratio IS NOT NULL
FROM ml_evaluate('pca_california', (SELECT *, 1 AS extra_col FROM california_test), version = 0);
----
1

query I
SELECT total_explained_variance_ratio IS NOT NULL
FROM ml_evaluate('pca_california', (SELECT * FROM california_train),
	version = 1);
----
1

statement error
SELECT * FROM ml_fit('unknown_model_type_test', {'model_type':'unknown'}, NULL, (SELECT MedInc FROM california_train));
----
Unsupported model_type

statement error
SELECT * FROM ml_explain('pca_california', (SELECT * FROM california_test));
----
ml_explain is not supported

statement error
SELECT * FROM ml_predict('missing_pca_model_name', (SELECT * FROM california_test));
----
No trained model named

statement error
SELECT * FROM ml_predict('pca_california',
	(SELECT MedInc, HouseAge, AveRooms, AveBedrms, Population, AveOccup, Latitude, Longitude
	 FROM california_test));
----
missing feature column

statement error
SELECT * FROM ml_evaluate('pca_california',
	(SELECT MedInc, HouseAge, AveRooms, AveBedrms, Population, AveOccup, Latitude, Longitude
	 FROM california_test));
----
missing feature column
