# name: test/sql/ml.test
# description: test ml extension
# group: [sql]

require ml

statement ok
PRAGMA threads=1;

statement ok
ATTACH 'test/datasets.duckdb' AS ds;

statement ok
CREATE OR REPLACE TEMP TABLE california AS SELECT * FROM ds.california;

statement ok
CREATE OR REPLACE TEMP TABLE california_train AS SELECT * FROM california LIMIT 16500;

statement ok
CREATE OR REPLACE TEMP TABLE california_test AS SELECT * FROM california LIMIT 4140 OFFSET 16500;

statement ok
CREATE OR REPLACE MACRO pca_model_blob() AS from_hex('');

query I
SELECT COUNT(*) FROM california;
----
20640

query I
WITH model AS (
	SELECT model AS m
	FROM ml_fit({'model_type':'pca', 'num_components':2, 'whiten':false}, NULL,
	            (SELECT * FROM california_train))
)
SELECT octet_length((SELECT m FROM model)) > 0;
----
1

query I
SELECT COUNT(*)
FROM ml_predict(pca_model_blob(), (SELECT * FROM california_test));
----
4140

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_predict(pca_model_blob(), (SELECT * FROM california_test)));
----
11

query I
SELECT ml_evaluate(pca_model_blob()) IS NOT NULL;
----
1

query I
SELECT total_explained_variance_ratio IS NOT NULL
FROM ml_evaluate(pca_model_blob(), (SELECT * FROM california_test));
----
1

statement error
SELECT * FROM ml_fit({'model_type':'unknown'}, NULL, (SELECT MedInc FROM california_train));
----
Unsupported model_type

statement error
SELECT * FROM ml_explain(pca_model_blob(), (SELECT * FROM california_test));
----
ml_explain is not supported
