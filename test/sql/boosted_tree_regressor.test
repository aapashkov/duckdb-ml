# name: test/sql/boosted_tree_regressor.test
# description: test boosted tree regressor model type
# group: [sql]

require ml

statement ok
PRAGMA threads=1;

statement ok
ATTACH 'test/datasets.duckdb' AS ds;

statement ok
CREATE OR REPLACE TEMP TABLE california AS SELECT * FROM ds.california;

statement ok
CREATE OR REPLACE TEMP TABLE california_train AS SELECT * FROM california LIMIT 16500;

statement ok
CREATE OR REPLACE TEMP TABLE california_test AS SELECT * FROM california LIMIT 4140 OFFSET 16500;

query I
SELECT COUNT(*)
FROM ml_fit(
	'btr_california',
	{'model_type':'boosted_tree_regressor', 'label':'MedHouseVal', 'tree_method':'hist', 'max_iterations':10},
	NULL,
	(SELECT * FROM california_train)
);
----
1

query I
SELECT COUNT(*)
FROM (
	DESCRIBE SELECT *
	FROM ml_fit(
		'btr_california',
		{'model_type':'boosted_tree_regressor', 'label':'MedHouseVal', 'tree_method':'hist', 'max_iterations':10},
		NULL,
		(SELECT * FROM california_train)
	)
);
----
7

query I
SELECT COUNT(*)
FROM (
	DESCRIBE SELECT *
	FROM ml_fit(
		'btr_california',
		{'model_type':'boosted_tree_regressor', 'label':'MedHouseVal', 'tree_method':'hist', 'max_iterations':10},
		NULL,
		(SELECT * FROM california_train)
	)
);
----
7

statement ok
CREATE OR REPLACE TEMP TABLE btr_fit_v1 AS
SELECT *
FROM ml_fit(
	'btr_california',
	{'model_type':'boosted_tree_regressor', 'label':'MedHouseVal', 'tree_method':'hist', 'max_iterations':10},
	NULL,
	(SELECT * FROM california_train)
);

statement ok
CREATE OR REPLACE TEMP TABLE btr_fit_v2 AS
SELECT *
FROM ml_fit(
	'btr_california',
	{'model_type':'boosted_tree_regressor', 'label':'MedHouseVal', 'tree_method':'hist', 'max_iterations':10},
	NULL,
	(SELECT * FROM california_train)
);

query I
SELECT (SELECT model_version FROM btr_fit_v2 LIMIT 1) = (SELECT model_version FROM btr_fit_v1 LIMIT 1) + 1;
----
1

query I
SELECT COUNT(*)
FROM ml_predict('btr_california', (SELECT * FROM california_test));
----
4140

query I
SELECT COUNT(*)
FROM ml_predict('btr_california', (SELECT *, 1 AS extra_col FROM california_test), version = 0);
----
4140

query I
SELECT COUNT(*)
FROM ml_predict('btr_california', (SELECT * FROM california_test),
	version = 1);
----
4140

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_predict('btr_california', (SELECT * FROM california_test)));
----
1

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_predict('btr_california', (SELECT *, 1 AS extra_col FROM california_test)));
----
1

query I
SELECT COUNT(*)
FROM ml_explain(
	'btr_california',
	(SELECT MedInc, HouseAge, AveRooms, AveBedrms, Population, AveOccup, Latitude, Longitude FROM california_test)
);
----
4140

query I
SELECT COUNT(*)
FROM ml_explain(
	'btr_california',
	(SELECT MedInc, HouseAge, AveRooms, AveBedrms, Population, AveOccup, Latitude, Longitude, 1 AS extra_col FROM california_test),
	version = 0
);
----
4140

query I
SELECT COUNT(*)
FROM (
	DESCRIBE SELECT *
	FROM ml_explain(
		'btr_california',
			(SELECT MedInc, HouseAge, AveRooms, AveBedrms, Population, AveOccup, Latitude, Longitude FROM california_test),
		version = 1
	)
);
----
9

query I
SELECT COUNT(*)
FROM (SELECT * FROM ml_evaluate('btr_california', (SELECT * FROM california_test)));
----
1

query I
SELECT COUNT(*)
FROM (DESCRIBE SELECT * FROM ml_evaluate('btr_california', (SELECT * FROM california_test)));
----
6

query I
SELECT COUNT(*)
FROM (SELECT * FROM ml_evaluate('btr_california', (SELECT *, 1 AS extra_col FROM california_test), version = 0));
----
1

statement error
SELECT *
FROM ml_predict('missing_btr_model_name', (SELECT * FROM california_test));
----
No trained model named

statement error
SELECT * FROM ml_fit(
	'btr_missing_label',
	{'model_type':'boosted_tree_regressor', 'label':'missing_label'},
	NULL,
	(SELECT * FROM california_train)
);
----
does not exist

statement error
SELECT * FROM ml_fit(
	'btr_non_numeric',
	{'model_type':'boosted_tree_regressor', 'label':'MedHouseVal'},
	NULL,
	(SELECT CAST(MedInc AS VARCHAR) AS MedInc, HouseAge, AveRooms, AveBedrms, Population, AveOccup, Latitude, Longitude, MedHouseVal
	 FROM california_train)
);
----
only supports numeric columns

